{
  "name": "llmconveyors-mcp",
  "version": "0.2.1",
  "mcpName": "io.github.ebenezer-isaac/llmconveyors",
  "description": "MCP server that connects AI agents to LLM Conveyors — run Job Hunter, B2B Sales, and other AI agents from Claude, Cursor, or any MCP client",
  "type": "module",
  "bin": {
    "llmconveyors-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "llm-conveyors",
    "ai-agents",
    "claude",
    "cursor",
    "job-hunting",
    "resume",
    "ats",
    "b2b-sales",
    "cold-email",
    "ai-tools"
  ],
  "author": "LLM Conveyors <hello@llmconveyors.com> (https://llmconveyors.com)",
  "license": "MIT",
  "homepage": "https://github.com/ebenezer-isaac/llmconveyors-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebenezer-isaac/llmconveyors-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ebenezer-isaac/llmconveyors-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "llmconveyors": "^0.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
