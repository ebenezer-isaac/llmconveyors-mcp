{
  "name": "@llmconveyors/mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing LLM Conveyors skills as tools for AI agents",
  "type": "module",
  "bin": {
    "llmconveyors-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "llm-conveyors",
    "ai-tools",
    "claude",
    "model-context-protocol"
  ],
  "author": "LLM Conveyors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "llmconveyors": "^0.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
